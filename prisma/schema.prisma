generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  password String
  name     String?
}

model Watch {
  id          String @id @default(cuid())
  name        String
  brand       String
  year        String
  description String
  imageSrc    String
}
